# Flask Configuration
# Generate a strong secret key with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-here-replace-in-production

# Server Configuration
PORT=5000
FLASK_ENV=development

# Database Configuration
# SQLite is used by default (instance/chatbot.db)
# For production, consider PostgreSQL or MySQL
SQLALCHEMY_DATABASE_URI=sqlite:///chatbot.db

# LLM API Configuration
# Configure your LLM provider
LLM_API_URL=https://janitorai.com/hackathon/completions
LLM_AUTH_TOKEN=your-llm-auth-token-here
MAX_OUT_TOKENS=400

# Feature Flags
ALLOW_GUESTS=false

# Logging
LOG_LEVEL=INFO
