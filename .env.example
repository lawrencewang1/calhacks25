# Flask Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ==============================================================================
# REQUIRED VARIABLES (Must be set for production)
# ==============================================================================

# Flask secret key for session management
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# JWT secret key for authentication tokens
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-jwt-secret-here

# LLM API authentication token
# Obtain from your LLM provider
LLM_AUTH_TOKEN=your-llm-token-here

# ==============================================================================
# ENVIRONMENT SETTINGS
# ==============================================================================

# Flask environment: development, production, or testing
FLASK_ENV=development

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Server port (optional, defaults to 5000)
PORT=5000

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================

# SQLite (Development - Default)
SQLALCHEMY_DATABASE_URI=sqlite:///chatbot.db

# PostgreSQL (Production - Recommended)
# SQLALCHEMY_DATABASE_URI=postgresql://username:password@localhost:5432/chatbot_db

# MySQL (Alternative)
# SQLALCHEMY_DATABASE_URI=mysql://username:password@localhost:3306/chatbot_db

# ==============================================================================
# SECURITY SETTINGS
# ==============================================================================

# CORS allowed origins (comma-separated)
# Development: Use "*" for all origins
# Production: Use specific domains only
# Example: https://example.com,https://app.example.com
CORS_ORIGINS=*

# ==============================================================================
# LLM API CONFIGURATION
# ==============================================================================

# LLM API endpoint URL
LLM_API_URL=https://janitorai.com/hackathon/completions

# Maximum output tokens for LLM responses
MAX_OUT_TOKENS=400

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================

# Allow guest users (not authenticated)
ALLOW_GUESTS=false

# ==============================================================================
# PRODUCTION DEPLOYMENT NOTES
# ==============================================================================
#
# SECURITY CHECKLIST:
# 1. Generate secure random secrets for SECRET_KEY and JWT_SECRET_KEY
# 2. Use PostgreSQL or MySQL for production databases, not SQLite
# 3. Restrict CORS_ORIGINS to your specific frontend domain(s)
# 4. Set FLASK_ENV=production in production environments
# 5. Use HTTPS in production - never HTTP
# 6. Never commit .env files to version control
# 7. Use environment-specific .env files (.env.production, .env.staging)
# 8. Consider using a secrets management system (AWS Secrets Manager, HashiCorp Vault)
#
# PASSWORD REQUIREMENTS (enforced by application):
# - Minimum 12 characters
# - At least one uppercase letter
# - At least one lowercase letter
# - At least one digit
# - At least one special character
#
# RATE LIMITING (enforced by application):
# - Registration: 5 per hour per IP
# - Login: 10 per minute per IP
# - Password change: 5 per hour per user
#
# ==============================================================================
